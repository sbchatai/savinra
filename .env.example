# ============================================================
# Savinra — Environment Variables Reference
# Copy to .env.local for local development (never commit .env.local)
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://rzknetoapokbwmyhvqac.supabase.co
VITE_SUPABASE_ANON_KEY=                          # from Supabase dashboard > API
VITE_SUPABASE_PUBLISHABLE_KEY=                   # new publishable key (alternative)

# Server-side / Edge Functions only (set via Vercel env or `supabase secrets set`)
# SUPABASE_SERVICE_ROLE_KEY=

# ── Razorpay ─────────────────────────────────────────────────
VITE_RAZORPAY_KEY_ID=                            # rzp_live_... or rzp_test_...
# RAZORPAY_KEY_SECRET=                           # Edge Functions only — never client
# RAZORPAY_WEBHOOK_SECRET=                       # from Razorpay dashboard > Webhooks

# ── AI / Image Generation ──────────────────────────────────────
# fal.ai — flux-lora product image generation
# FAL_API_KEY=                                   # Edge Functions / n8n

# ── Shipping ──────────────────────────────────────────────────
# SHIPROCKET_EMAIL=                              # n8n workflows
# SHIPROCKET_PASSWORD=

# ── Communications ────────────────────────────────────────────
# WhatsApp Business API (Interakt / WATI / Meta direct)
# WHATSAPP_API_KEY=                              # n8n / Edge Functions
# WHATSAPP_PHONE_NUMBER_ID=

# Email (Resend)
# RESEND_API_KEY=                                # Edge Functions
# EMAIL_FROM=hello@savinra.com

# ── Third-party APIs ──────────────────────────────────────────
VITE_GOOGLE_PLACES_API_KEY=                      # pincode autocomplete (restrict to domain)

# Anthropic (for AI chat / product descriptions)
# ANTHROPIC_API_KEY=                             # Edge Functions only

# ── App Config ────────────────────────────────────────────────
VITE_APP_URL=https://savinra-store.vercel.app
VITE_SUPPORT_WHATSAPP=+919876543210              # update with client's actual number

# ── Local Dev Overrides ───────────────────────────────────────
# Uncomment to point at local Supabase instance (`supabase start`)
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=your-local-anon-key
